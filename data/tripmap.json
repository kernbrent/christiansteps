  {
    "Date": "2026-05-18",
    "Title": "Lucerne Excursion to Jungfrau",
    "City": "Lucerne",
    "Country": "Switzerland",
    "Latitude": 47.0502,
    "Longitude": 8.3093,
    "MissionDay": false,
    "Travelers": [
      "Brent",
      "Corrie",
      "Lily",
      "Ethan",
      "Bill"
    ],
    "Transportation": {
      "Type": "Excursion",
      "Icon": "🏔️",
      "Description": "Today was very rainy throughout the day. We took a boat/ferry ride across Lake Lucerne to Mt Rigi. We took a Cog Train up to the top of Mt Rigi. The rain turned to snow. IT was very fogging, but it was quite nice. We walked part way down and took the ferry back to Lucerne. We had a great lunch on the Mountain - \"Wienerschnitzel\" We then climbed to the Lucerne City Wall call \"Musegg Wall\". It was a surprisingly fun experience."
    },
